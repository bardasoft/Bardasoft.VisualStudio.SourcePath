# GitHub Linguist configuration for Bardasoft SourcePath
# This file fixes the repository language statistics shown by GitHub.

# Main project language
*.cs linguist-language=C#
*.csproj linguist-language=XML
*.sln linguist-language=Text
*.vsixmanifest linguist-language=XML

# Scripts are useful project tools, but they should not define the main repository language.
*.bat linguist-generated=true
*.cmd linguist-generated=true
*.ps1 linguist-generated=true

# Documentation and assets should not dominate the repository language.
*.md linguist-documentation=true
*.txt linguist-documentation=true
*.png linguist-generated=true
*.jpg linguist-generated=true
*.jpeg linguist-generated=true
*.svg linguist-generated=true

# Build/output folders should never count if they accidentally appear in the repository.
bin/** linguist-generated=true
obj/** linguist-generated=true
.vs/** linguist-generated=true
